{
	"name": "moonkake",
	"description": "Site starter template based on Vite, Scss, Pug/Twig, JS",
	"version": "10.6.1",
	"author": {
		"name": "DevBrains",
		"url": "https://devbrains.io"
	},
	"homepage": "https://github.com/pro-verstka/moonkake#readme",
	"repository": {
		"type": "git",
		"url": "git://github.com/pro-verstka/moonkake.git"
	},
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"tools:format": "biome format ./src ./config ./vite.config.js --fix",
		"tools:lint": "biome check ./src ./config ./vite.config.js --fix",
		"tools:generate": "plop",
		"prepare": "husky",
		"lint-staged": "lint-staged"
	},
	"dependencies": {
		"flatpickr": "4.6.13",
		"fontfaceobserver": "2.3.0",
		"gsap": "3.15.0",
		"imask": "7.6.1",
		"photoswipe": "5.4.4",
		"scroll-to-element": "2.0.3",
		"scrollbooster": "3.0.2",
		"swiper": "12.1.3",
		"tippy.js": "6.3.7",
		"validate.js": "0.13.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@vituum/vite-plugin-pug": "2.0.1",
		"@vituum/vite-plugin-twig": "2.0.1",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"plop": "4.0.5",
		"sass-embedded": "1.99.0",
		"vite": "8.0.10",
		"vite-plugin-checker": "0.13.0"
	},
	"engines": {
		"node": ">=24.14.0"
	},
	"volta": {
		"node": "24.14.0"
	}
}
